    .dia-fecha { display: block; font-weight: bold; margin-bottom: 8px; color: #fff; font-size: 1.1rem; }
    .dia-estado { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; margin-bottom: 10px; font-weight: bold; }
    .dia-estado.cerrado { background: rgba(255, 107, 107, 0.15); color: #ff6b6b; border: 1px solid rgba(255, 107, 107, 0.3); }
    .dia-estado.abierto { background: rgba(46, 204, 113, 0.15); color: #2ecc71; border: 1px solid rgba(46, 204, 113, 0.3); }
    .btn-small-delete { background: transparent; color: #ff6b6b; border: 1px solid rgba(255, 107, 107, 0.3); padding: 4px 8px; border-radius: 4px; font-size: 0.65rem; font-weight: bold; text-transform: uppercase; cursor: pointer; text-decoration: none; transition: 0.2s; margin-top: 8px; display: inline-block; }
    .btn-small-delete:hover { background: #ff6b6b; color: #fff; }
    .text-muted { opacity: 0.4; font-size: 0.9rem; font-style: italic; }
    .toast-success { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); background: #2ecc71; color: #000; padding: 12px 24px; border-radius: 50px; z-index: 1000; font-weight: bold; box-shadow: 0 5px 20px rgba(0,0,0,0.3); }
    .toast-error { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); background: #e74c3c; color: #fff; padding: 12px 24px; border-radius: 50px; z-index: 1000; font-weight: bold; }
    .empty-state { padding: 50px; text-align: center; opacity: 0.5; }
    :global(.flatpickr-calendar) { background: #1a1a1a !important; border: 1px solid rgba(242, 240, 230, 0.2) !important; box-shadow: 0 10px 40px rgba(0,0,0,0.5) !important; }
    :global(.flatpickr-months .flatpickr-month) { background: #1a1a1a !important; color: var(--color-bg-beige) !important; fill: var(--color-bg-beige) !important; }
    :global(.flatpickr-current-month .flatpickr-monthDropdown-months) { background: #1a1a1a !important; }
    :global(.flatpickr-weekdays) { background: #1a1a1a !important; }
    :global(span.flatpickr-weekday) { color: rgba(242, 240, 230, 0.6) !important; }
    :global(.flatpickr-day) { color: var(--color-bg-beige) !important; }
    :global(.flatpickr-day:hover) { background: rgba(242, 240, 230, 0.2) !important; border-color: transparent !important; }
    :global(.flatpickr-day.selected), :global(.flatpickr-day.selected:hover) { background: var(--color-bg-beige) !important; color: var(--color-text-black) !important; border-color: var(--color-bg-beige) !important; font-weight: bold; }
